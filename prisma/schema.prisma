generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int    @id @default(autoincrement())
  firstname String
}

model Car {
  id    Int    @id @default(autoincrement())
  brand String
  model String
  price Float
}

// 🟢 NY MODEL: Category
model Category {
  id   Int    @id @default(autoincrement())
  name String
}

// 🟢 NY MODEL: Brand
model Brand {
  id   Int    @id @default(autoincrement())
  name String
  logo String // Tekststreng til f.eks. en URL eller filsti til et logo-billede
}