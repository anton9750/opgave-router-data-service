generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int    @id @default(autoincrement())
  firstname String
}

model Car {
  id    Int    @id @default(autoincrement())
  brand String
  model String
  price Float
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model Brand {
  id   Int    @id @default(autoincrement())
  name String @unique
  logo String
}